{
  "builds": [
    {
      "src": "**/*.php",
      "use": "vercel-php@0.6.1"
    }
  ],
  "routes": [
    {
      "src": "/assets/(.*)",
      "dest": "/assets/$1"
    },
    {
      "src": "/(.*).php",
      "dest": "/$1.php"
    },
    {
      "src": "/(.*)",
      "dest": "/$1.php"
    }
  ]
}
